{
  "name": "spendwise",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write .",
    "prepare": "husky || exit 0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,ts,tsx,json,md}": [
      "prettier --write --no-error-on-unmatched-pattern"
    ],
    "*.{ts,tsx}": [
      "node ./scripts/run-eslint-legacy.cjs --fix --no-error-on-unmatched-pattern"
    ]
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vercel": "^50.38.2"
  }
}
